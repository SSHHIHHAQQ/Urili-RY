<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.PortalAccountMapper">

    <select id="countSellerAccountByUserId" parameterType="Long" resultType="int">
        select count(1)
        from seller_account
        where user_id = #{userId}
    </select>

    <select id="countBuyerAccountByUserId" parameterType="Long" resultType="int">
        select count(1)
        from buyer_account
        where user_id = #{userId}
    </select>

</mapper>
