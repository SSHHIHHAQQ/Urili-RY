# RuoYi backend runtime configuration
RUOYI_DB_URL=jdbc:mysql://example-host:3306/example_db?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true&nullCatalogMeansCurrent=true
RUOYI_DB_USERNAME=example_user
RUOYI_DB_PASSWORD=change_me

RUOYI_REDIS_HOST=example-host
RUOYI_REDIS_PORT=6379
RUOYI_REDIS_DATABASE=0
RUOYI_REDIS_PASSWORD=change_me

RUOYI_DRUID_USERNAME=ruoyi
RUOYI_DRUID_PASSWORD=change_me
RUOYI_TOKEN_SECRET=change_me
